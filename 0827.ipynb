   "source": [
    "def solution(d):\n",
    "    decimal=[]\n",
    "    while d>1:\n",
    "        decimal.append(d%2)\n",
    "        d=d//2\n",
    "    decimal.append(d)\n",
    "\n",
    "    decimal.reverse()\n",
    "\n",
    "    return decimal"
   ]
